{
  "name": "Poll",
  "componentType": "poll",
  "fields": [
    {
      "key": "title",
      "label": "Title",
      "type": "text",
      "scope": "global",
      "defaultValue": "Poll"
    },
    {
      "key": "fontFamily",
      "label": "Font",
